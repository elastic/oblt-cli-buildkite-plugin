#!/usr/bin/env bash

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

OBLT_CLI_USERNAME="${BUILDKITE_PLUGIN_OBLT_CLI_USERNAME:-obltmachine}"
OBLT_CLI_SLACK_CHANNEL="${BUILDKITE_PLUGIN_OBLT_CLI_SLACK_CHANNEL:-#observablt-bots}"
OBLT_CLI_VERSION="${BUILDKITE_PLUGIN_OBLT_CLI_VERSION:-}"
OBLT_CLI_VERSION_FILE="${BUILDKITE_PLUGIN_OBLT_CLI_VERSION_FILE:-"${DIR}/../.default-oblt-cli-version"}"
OBLT_CLI_ORG="${BUILDKITE_PLUGIN_OBLT_CLI_ORG:-}"
OBLT_CLI_DIVISION="${BUILDKITE_PLUGIN_OBLT_CLI_DIVISION:-}"
OBLT_CLI_PROJECT="${BUILDKITE_PLUGIN_OBLT_CLI_PROJECT:-}"
OBLT_CLI_TEAM="${BUILDKITE_PLUGIN_OBLT_CLI_TEAM:-}"

if [[ -z ${VAULT_GITHUB_TOKEN} ]]; then
	>&2 echo "The VAULT_GITHUB_TOKEN environment variable must be set."
	exit 1
fi

if [[ -z ${OBLT_CLI_ORG} ]]; then
	>&2 echo "The 'org' plugin property is required."
	exit 1
fi

if [[ -z ${OBLT_CLI_DIVISION} ]]; then
	>&2 echo "The 'division' plugin property is required."
	exit 1
fi

if [[ -z ${OBLT_CLI_PROJECT} ]]; then
	>&2 echo "The 'project' plugin property is required."
	exit 1
fi

if [[ -z ${OBLT_CLI_TEAM} ]]; then
	>&2 echo "The 'team' plugin property is required."
	exit 1
fi

# shellcheck disable=SC1091
. "${DIR}/../lib/setup.bash"

git config --global user.name "${GIT_USER:-"${OBLT_CLI_USERNAME}"}"
git config --global user.email "${GIT_EMAIL:-"${OBLT_CLI_USERNAME}@users.noreply.github.com"}"

VERSION=$(get_version_from_input_or_file "${OBLT_CLI_VERSION}" "${OBLT_CLI_VERSION_FILE}")
echo "~~~ :elastic-apm: Set up oblt-cli ${VERSION}"
setup "${VERSION}" "${OBLT_CLI_USERNAME}" "${OBLT_CLI_SLACK_CHANNEL}" "${OBLT_CLI_BIN}" "${OBLT_CLI_ORG}" "${OBLT_CLI_DIVISION}" "${OBLT_CLI_PROJECT}" "${OBLT_CLI_TEAM}"
